# --- Snappy Futuristic Animations ---
settings put global window_animation_scale 0.2
settings put global transition_animation_scale 0.2
settings put global animator_duration_scale 0.2

# --- Bluish-Pinkish Material You Palette ---
# This forces a Neon Pink (#FF00FF) and Cyan (#00FFFF) vibe
settings put secure theme_customization_overlay_packages '{"android.theme.customization.system_palette":"#FF00FF", "android.theme.customization.accent_color":"#00FFFF", "android.theme.customization.theme_style":"EXPRESSIVE"}'

# --- Advanced High-Res UI (DPI Change) ---
# Makes things smaller/more "pro" looking. Adjust 380 to your liking.
wm density 380

# --- Clean Author Mode ---
# Hides the gesture bar at the bottom for a seamless look
settings put global policy_control immersive.navigation=*

echo "Vibe applied. Welcome to the future."
# Force "Cotton Candy" Palette: Pink Accents (#FF69B4) + Cyan Backgrounds (#E0FFFF)
settings put secure theme_customization_overlay_packages '{"android.theme.customization.system_palette":"#FF69B4","android.theme.customization.accent_color":"#00FFFF","android.theme.customization.theme_style":"EXPRESSIVE"}'

# Make the UI "Glassy" (Reduce transparency contrast for a futuristic look)
settings put secure accessibility_reduce_transparency 0
# Enable Freeform Windows (Allows you to float apps like Windows 10/11)
settings put global enable_freeform_support 1

# Force "Desktop Mode" on secondary displays (or Limbo sessions)
settings put global force_desktop_mode_on_external_displays 1

# Set a "Pro" Screen Density
# 420 is standard; 360 is "large"; 480+ is "tiny/advanced"
wm density 400
# Hide the "Vibrate," "Bluetooth," and "Alarm" icons for a cleaner look
settings put secure icon_blacklist vibrate,bluetooth,alarm_clock,volume

# Move the Clock to the center (if supported by your ROM/Skin)
# Note: This works best with the "SystemUI Tuner" app from GitHub
# Disable "Absolute Volume" (Gives you more granular control over your IEM volume)
settings put global btsession_absolute_volume_disabled 1

# "Author Mode" - Disable Heads-up Notifications (Stops popups while writing)
settings put global heads_up_notifications_enabled 0
# Create a shortcut for a "Liturgical Theme" 
# Run this command to swap to Purple/Gold colors during Lent/Easter
# settings put secure theme_customization_overlay_packages '{"android.theme.customization.accent_color":"#800080"}'

# Enable Freeform Windows (The ultimate Windows-vibe feature)
settings put global enable_freeform_support 1

# Force every app to be resizable (even if the developer blocked it)
settings put global force_resizable_activities 1

# Enable "Desktop Mode" (This triggers a more PC-like UI when you multi-task)
settings put global force_desktop_mode_on_external_displays 1
# Force a Neon Pink (#FF1493) and Deep Cyan (#00CED1) Palette
# The 'EXPRESSIVE' style makes the colors pop much harder than normal
settings put secure theme_customization_overlay_packages '{"android.theme.customization.system_palette":"#FF1493","android.theme.customization.accent_color":"#00CED1","android.theme.customization.theme_style":"EXPRESSIVE"}'

# Make the Quick Settings tiles use your custom pinkish glow
settings put secure sysui_type_accent_color #FF69B4
# Disable "Absolute Volume" (Gives your IEMs 100 levels of volume instead of 15)
settings put global btsession_absolute_volume_disabled 1

# Disable "Heads-up" Notifications (Stops those annoying popups while you're writing)
settings put global heads_up_notifications_enabled 0

# Force 120Hz Refresh Rate (Make the bluish-pinkish UI feel like liquid)
# Note: Use 'wm refresh_rate 120' if your phone hardware supports it

# --- ARCHITECTURE OVERRIDE ---
# Force "Game Driver" logic for the entire System UI (smoother bluish-pinkish gradients)
settings put global updatable_driver_all_apps 1

# --- INPUT PRECISION (BlackBerry/Handheld PC Style) ---
# Disable "Touch Exploration" and "Pointer Acceleration" for raw, robotic input feel
settings put system pointer_speed 7
settings put secure long_press_timeout 200 # Makes the UI feel incredibly responsive

# --- ADVANCED WINDOWING ---
# Allow windows to overlap and "Snap" like Windows 11
settings put global pinner_flags 1
# --- THE INVISIBLE STATUS BAR ---
# This wipes the top bar completely. No clock, no battery, no distractions. 
# It looks like a clean, futuristic slab of glass.
settings put secure icon_blacklist battery,wifi,bluetooth,cell,alarm_clock,vibrate,zen,volume,location

# --- NEON INJECTION (The "Cyber-Glow") ---
# We are forcing a "Chromecast" style color palette: Deep Magenta & Electric Cyan
settings put secure theme_customization_overlay_packages '{"android.theme.customization.color_both":"1","android.theme.customization.color_source":"#FF00FF","android.theme.customization.theme_style":"TONAL_SPOT"}'

# --- THE "GLASS" EFFECT ---
# Force the Blur effect on all windows (If your phone supports Android 14/15 blurs)
# This gives it that expensive, high-end PC look.
settings put global disable_window_blurs 0
# Every time you run this, it sends a 'Heartbeat' to your GitHub
# This makes it look like you're monitoring a remote server (your phone)
curl -u YOUR_GITHUB_USER:YOUR_TOKEN -X PUT -d "{\"message\":\"Vibe Check\",\"content\":\"$(date | base64)\"}" https://api.github.com/repos/YOUR_USER/my-phone-vibe/contents/system_log.txt
# This code disables the "Recents" button so no one can see what you were 
# writing if they grab your phone. You have to "Code" your way back in.
settings put secure navbar_buttons_managed_by_parent 1

# --- DATA STREAM LOCKSCREEN ---
# This forces the phone to show "Developer Logs" over the UI for 2 seconds
# making it look like a futuristic PC booting up.
settings put global show_processes 1
sleep 2
settings put global show_processes 0

# --- THE "AUTHORIZED USER" LOCKSCREEN ---
# Change the lockscreen message to look like a BIOS terminal
settings put system lock_screen_owner_info "OS_VERSION_2.6.0_STABLE // AUTHORIZED_USER: ADRIEL // ENCRYPTION_ACTIVE"
settings put system lock_screen_owner_info_enabled 1
