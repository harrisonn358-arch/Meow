settings put global transition_animation_scale 0.0
settings put global animator_duration_scale 0.0
# --- CYBER-COTTON-CANDY MATRIX ---
# Deep Navy (#00001A) | Neon Pink (#FF00FF) | Electric Cyan (#00FFFF)
