# This forces the phone to allow "Floating Windows" for EVERY app
settings put global enable_freeform_support 1
settings put global force_resizable_activities 1

# --- THE "GLASS" UI EFFECT ---
# If your phone supports it, this increases the "blur" behind windows
# giving it that expensive, futuristic look.
settings put global disable_window_blurs 0
# --- NEON MATRIX COLORS ---
